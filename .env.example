# ─────────────────────────────────────────────────────────────
# Pearloom — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# Markers:
#   [REQUIRED]  app will not boot / core flow breaks without this
#   [PROD]      MUST be set on production deploys (default works in dev)
#   [OPTIONAL]  feature degrades gracefully when missing
#
# Audited 2026-05-29 (Phase 3.5 of docs/AUDIT-2026-05-29.md).
# Every variable below is one process.env.X reference the code
# actually reads. If you add a new env var to the codebase, add
# it here in the same commit.
# ─────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────
# [REQUIRED] Without these the app boots but every persisted flow
# (sites, RSVPs, photos, payments, GDPR export/delete) silently
# degrades. The service-role key bypasses RLS — only use it
# server-side; NEVER expose it to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ── Auth (NextAuth + Google OAuth) ────────────────────────────
# [REQUIRED]
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here

# [PROD] Localhost works in dev. In production this MUST match
# your deployment URL exactly (scheme + host, no trailing slash):
#   prod:    https://pearloom.com
#   preview: https://pearloom-git-<branch>.vercel.app
# Wrong NEXTAUTH_URL → OAuth callback rejected by Google with
# redirect_uri_mismatch. Multi-region deploys: pin to the
# canonical origin, not the per-region URL.
NEXTAUTH_URL=http://localhost:3000


# ── AI: Gemini (Google) ───────────────────────────────────────
# [REQUIRED] Powers wizard generation, photo stylize fallback,
# block rewrites, FAQ drafting, meals, hotels, follow-ups, etc.
# GOOGLE_AI_KEY and GOOGLE_API_KEY are aliases — set one of them.
GEMINI_API_KEY=your-gemini-api-key


# ── AI: Anthropic (Claude) ────────────────────────────────────
# [REQUIRED] Inline rewrites (Pear's text rewrite tool) call
# Claude. ai-chat falls back gracefully without it; inline-rewrite
# returns the original text and closes the busy state.
ANTHROPIC_API_KEY=sk-ant-...

# [OPTIONAL] Per-feature Claude model overrides. Defaults are
# sensible — only set these to swap models without a deploy.
# PEARLOOM_CLAUDE_CHAT=claude-opus-4-7
# PEARLOOM_CLAUDE_STORY=claude-sonnet-4-6


# ── AI: OpenAI (gpt-image-2) ──────────────────────────────────
# [REQUIRED for /api/photos/stylize] OpenAI image is the primary
# path; Gemini Nano Banana is the fallback when this is absent.
# gpt-image-2 preserves faces / venue identity better — without
# OPENAI_API_KEY, Save-the-Date stylize quality regresses.
OPENAI_API_KEY=sk-...
# [OPTIONAL] override the model id (default is gpt-image-2)
# OPENAI_IMAGE_MODEL=gpt-image-2


# ── Billing (Stripe) ──────────────────────────────────────────
# [REQUIRED for monetization] Without these, /api/payments and
# the webhook 503 — checkout flow disabled, plan upgrade impossible.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
# [PROD] Get this from the Stripe dashboard webhook config.
# Without it the webhook 503s every event — payments + registry
# claims won't sync.
STRIPE_WEBHOOK_SECRET=whsec_...


# ── Storage (Cloudflare R2 — primary) ─────────────────────────
# [REQUIRED for photo uploads + AI generation outputs]
# When missing, /api/photos/upload falls back to Supabase Storage
# (if configured). Without either, the upload route 500s.
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=pearloom-photos
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-bucket.r2.dev

# [OPTIONAL] Server-side AES-256 encryption of R2 photo blobs.
# Generate with: openssl rand -hex 32. When set, photos are
# encrypted at rest with this key and decrypted on read via
# /api/img/<key>. Rotating breaks every photo URL — pick once.
# PEARLOOM_ENCRYPTION_KEY=64-hex-chars


# ── Email (Resend) ────────────────────────────────────────────
# [REQUIRED for invites + RSVP confirmation + day-of broadcast]
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@pearloom.com
# [OPTIONAL] Host-side notification when a guest RSVPs.
NOTIFICATION_EMAIL=you@example.com
# [OPTIONAL] Webhook signature verification for delivery events
# (bounce / unsubscribe). Without it, the webhook accepts unsigned
# events — fine in dev, configure in prod.
RESEND_WEBHOOK_SECRET=whsec_...


# ── Print fulfillment (Lob) ───────────────────────────────────
# [OPTIONAL] Physical Save-the-Date / invite postal sending via
# /api/print/lob. Without it, the print panel shows a "not configured"
# state and the host can still export PDFs manually.
LOB_API_KEY=test_...


# ── Maps (Google Places) ──────────────────────────────────────
# [OPTIONAL] Powers the wizard's venue + address autocomplete,
# the editor's TravelMapSearch + hotel finder, and the
# /api/places/{search,details} + /api/hotels/{nearby,enrich}
# routes. Without it, hosts type addresses freehand and the
# travel section degrades to a curated demo dataset — works but
# rougher.
GOOGLE_PLACES_API_KEY=AIza...


# ── Rate limiting (Upstash Redis) ─────────────────────────────
# [OPTIONAL] Multi-region-safe rate limiter. Without these,
# /api/places/* + /api/hotels/* + any other route that calls
# checkRateLimitAsync falls back to the in-memory limiter
# (src/lib/rate-limit.ts) — which is fine on a single instance
# (dev, Vercel preview) but on multi-region production each region
# runs its own Map so a caller can exceed the limit by N× by
# hitting N regions in parallel.
#
# When set, the limiter switches to fixed-window buckets in
# Redis via Upstash's REST API. Algorithm: INCR per bucket key
# (key + floor(now/windowMs)), EXPIRE on first hit. Fails OPEN
# to in-memory on any Redis error, so an Upstash outage degrades
# to current behavior, not a 500.
#
# Get the URL + token from https://console.upstash.com → Redis
# database → REST API tab. Use the regional Global database for
# lowest cross-region latency.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── Cron + scheduled jobs ─────────────────────────────────────
# [PROD] Shared secret for /api/cron/* endpoints (anniversary
# emails, time-capsule reveals, etc.). Without it the cron
# endpoints 401 every request — jobs silently never run.
CRON_SECRET=generate-a-random-secret-here


# ── Push notifications (Web Push / VAPID) ─────────────────────
# [OPTIONAL] Used by the future push-notification surface. The
# VAPID keys must form a matched pair — generate with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@pearloom.com


# ── Error monitoring (Sentry) ─────────────────────────────────
# [PROD] Wiring lives in sentry.{server,client,edge}.config.ts —
# every Sentry.init is gated on the DSN env var below, so dev runs
# without these stay console-only and pay no SDK cost.
#
# Set BOTH SENTRY_DSN (server runtime — route handlers, middleware,
# Node API code) AND NEXT_PUBLIC_SENTRY_DSN (browser bundle) with
# the same Sentry project DSN. The split is required because
# NEXT_PUBLIC_* is the only env var prefix Next.js inlines into
# client code; the server runtime reads the un-prefixed name.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# [OPTIONAL — CI only] Source-map upload at build time so Sentry
# can symbolicate stack traces back to your TypeScript source.
# Without these the wrapper is a transparent passthrough. Get
# SENTRY_AUTH_TOKEN from sentry.io → Settings → Auth Tokens (it
# needs the `project:write` scope).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# ── App ───────────────────────────────────────────────────────
# [PROD] The canonical public origin Pearloom emits in URLs
# (invite links, OG cards, email CTAs, calendar feeds, OAuth
# callback fallbacks). Without this set in prod, getAppOrigin()
# falls back to 'https://pearloom.com' which is fine if that's
# you but breaks for any custom-domain deploy. Set it.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# [OPTIONAL] Root domain for subdomain routing. Currently we use
# path-based URLs (pearloom.com/<occasion>/<slug>) so this is rarely
# needed; reserved for future subdomain support.
# NEXT_PUBLIC_ROOT_DOMAIN=pearloom.com


# ── E2E (Playwright) ──────────────────────────────────────────
# [LOCAL ONLY] Set PEARLOOM_E2E=1 before `npm run test:e2e` so the
# auth provider registers the credentials path the global-setup
# uses. NEVER set this in production — it bypasses Google OAuth.
# PEARLOOM_E2E=1
# E2E_TEST_USER_EMAIL=e2e@pearloom.test
# E2E_TEST_USER_PASSWORD=pearloom-e2e-secret
