{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/brand/**",
              "components/core/**",
              "components/motifs/**",
              "design_handoff_pearloom_dashboard_editor/**",
              "site-editor/**",
              "site-renderer/**",
              "ui_kits/dashboard/**",
              "ui_kits/editor/**",
              "ui_kits/marketing/**",
              "ui_kits/renderer/**",
              "ui_kits/wallpapers/**",
              "ui_kits/wizard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Geist|Geist Mono|Caveat))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Geist, Geist Mono, Caveat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|dot|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, dot, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:olive|gold|plum|neutral|ink)$/]",
        "message": "<Badge> tone must be one of 'olive' | 'gold' | 'plum' | 'neutral' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:label|pill)$/]",
        "message": "<Badge> variant must be one of 'label' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|onClick|disabled|type|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, onClick, disabled, type, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ink|olive|paper|terra|ghost|pearl)$/]",
        "message": "<Button> variant must be one of 'ink' | 'olive' | 'paper' | 'terra' | 'ghost' | 'pearl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|interactive|padding|as|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, interactive, padding, as, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:ornament|width|color|accent|ink|weight|className|style|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: ornament, width, color, accent, ink, weight, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='ornament'] > Literal[value!=/^(?:fleuron|pearl|diamond|sprig|infinity|sun|cross)$/]",
        "message": "<Divider> ornament must be one of 'fleuron' | 'pearl' | 'diamond' | 'sprig' | 'infinity' | 'sun' | 'cross'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|rule|color|ruleColor|className|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, rule, color, ruleColor, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='rule'] > Literal[value!=/^(?:leading|trailing|both|none)$/]",
        "message": "<Eyebrow> rule must be one of 'leading' | 'trailing' | 'both' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|value|defaultValue|onChange|placeholder|type|multiline|rows|disabled|id|className|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, value, defaultValue, onChange, placeholder, type, multiline, rows, disabled, id, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Folio'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|no|label|direction|ruleColor|color|rules|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Folio> doesn't accept that prop. Declared props: kicker, no, label, direction, ruleColor, color, rules, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Folio'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:row|column)$/]",
        "message": "<Folio> direction must be one of 'row' | 'column'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Folio'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md)$/]",
        "message": "<Folio> size must be one of 'xs' | 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Monogram'] > JSXAttribute > JSXIdentifier[name!=/^(?:left|right|single|frame|size|ink|accent|paper|showAmp|className|style|key|ref|className|style|children)$/]",
        "message": "<Monogram> doesn't accept that prop. Declared props: left, right, single, frame, size, ink, accent, paper, showAmp, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Monogram'] > JSXAttribute[name.name='frame'] > Literal[value!=/^(?:plain|ring|crest|wreath|diamond|interlock)$/]",
        "message": "<Monogram> frame must be one of 'plain' | 'ring' | 'crest' | 'wreath' | 'diamond' | 'interlock'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Motif'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|accent|weight|className|style|key|ref|className|style|children)$/]",
        "message": "<Motif> doesn't accept that prop. Declared props: name, size, color, accent, weight, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pearl'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|iridescent|style|key|ref|className|style|children)$/]",
        "message": "<Pearl> doesn't accept that prop. Declared props: size, iridescent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PearloomGlyph'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|gold|paper|className|style|key|ref|className|style|children)$/]",
        "message": "<PearloomGlyph> doesn't accept that prop. Declared props: size, color, gold, paper, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Thread'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|width|height|color|color2|weight|className|style|key|ref|className|style|children)$/]",
        "message": "<Thread> doesn't accept that prop. Declared props: variant, width, height, color, color2, weight, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Thread'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:weave|straight|single|bullet)$/]",
        "message": "<Thread> variant must be one of 'weave' | 'straight' | 'single' | 'bullet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WeaveLoader'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|color|color2|weight|inline|className|style|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<WeaveLoader> doesn't accept that prop. Declared props: size, label, color, color2, weight, inline, className, style, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='WeaveLoader'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<WeaveLoader> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
